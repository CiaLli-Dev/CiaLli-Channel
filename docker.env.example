# Docker/Compose 演示环境变量示例
# 复制为 docker.env 后再执行 docker compose --env-file docker.env up -d --build

# 站点对外访问地址。演示环境建议显式配置，避免 RSS/Atom/Sitemap 输出为容器内地址。
APP_SITE_URL=http://localhost:4321

# 是否信任反向代理透传的 X-Forwarded-* 头。
# 仅在你明确有 HTTPS 终止代理时设为 1；本地直连演示保持 0。
APP_TRUST_PROXY=0

# Docker 演示版默认关闭 Vercel Analytics / Speed Insights。
ENABLE_VERCEL_ANALYTICS=0

# Directus 实例地址
DIRECTUS_URL=

# 服务端访问 Directus 的静态 Token
DIRECTUS_STATIC_TOKEN=

# Bangumi AccessToken 加密密钥（base64 编码的 32-byte key）
BANGUMI_TOKEN_ENCRYPTION_KEY=

# 可选：公开资源基础地址（用于图床）
PUBLIC_ASSET_BASE_URL=

# 可选：Upstash Redis。未配置时将自动降级到单实例内存缓存/限流。
KV_REST_API_URL=
KV_REST_API_TOKEN=

# 当启用了 Upstash Redis 时，生产环境建议显式隔离 namespace。
REDIS_NAMESPACE=demo:docker
