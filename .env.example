# CiaLli 统一环境变量示例
# 复制此文件为 .env，并同时供本地开发与 Docker Compose 使用

# ============================================
# 站点与入口
# ============================================

APP_PUBLIC_BASE_URL=https://localhost
APP_PUBLIC_HOSTNAME=localhost
ACME_EMAIL=ops@example.com

# ============================================
# Directus（主机访问 vs 容器内访问）
# ============================================

DIRECTUS_URL=http://127.0.0.1:8055
DIRECTUS_INTERNAL_URL=http://directus:8055
DIRECTUS_PUBLIC_URL=http://127.0.0.1:8055

DIRECTUS_STATIC_TOKEN=
DIRECTUS_SECRET=change-me
DIRECTUS_KEY=change-me-too
DIRECTUS_ADMIN_EMAIL=demo-admin@example.com
DIRECTUS_ADMIN_PASSWORD=CiaLli-demo-admin-2026!

# ============================================
# PostgreSQL / Redis / MinIO
# ============================================

POSTGRES_DB=directus
POSTGRES_USER=directus
POSTGRES_PASSWORD=change-me

REDIS_URL=redis://127.0.0.1:6379/0
REDIS_INTERNAL_URL=redis://redis:6379/0
DIRECTUS_REDIS_URL=redis://redis:6379
REDIS_NAMESPACE=dev:local

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me
MINIO_BUCKET=cialli-assets

# ============================================
# Directus Storage Locations
# 默认仅保留对象存储；历史 local 文件如需迁移，请先执行迁移脚本再切换配置
# ============================================

STORAGE_LOCATIONS=s3

STORAGE_S3_DRIVER=s3
STORAGE_S3_KEY=minioadmin
STORAGE_S3_SECRET=change-me
STORAGE_S3_BUCKET=cialli-assets
STORAGE_S3_REGION=us-east-1
STORAGE_S3_ENDPOINT=http://minio:9000
STORAGE_S3_FORCE_PATH_STYLE=true

# ============================================
# 应用业务变量
# ============================================

# Bangumi AccessToken 加密密钥（base64 编码的 32-byte key）
# 生成示例：node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
BANGUMI_TOKEN_ENCRYPTION_KEY=

# 可选：公开资源基础地址
# 默认留空，继续统一走站内 BFF 代理（/api/v1/public/assets/:id）
PUBLIC_ASSET_BASE_URL=

# ============================================
# AI Summary Worker
# ============================================

AI_SUMMARY_INTERNAL_SECRET=
AI_SUMMARY_DIRECTUS_TOKEN=
AI_SUMMARY_WORKER_PORT=4322
